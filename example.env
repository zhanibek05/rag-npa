# Core paths
INDEX_PATH=./data/faiss.index
META_PATH=./data/chunks_meta.jsonl

# Embeddings
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DEVICE=cuda
# Retrieval mode: semantic | lexical
# On macOS use lexical by default to avoid torch native crashes in some envs.
RETRIEVAL_MODE=lexical

# LLM provider: ollama | openai
LLM_PROVIDER=ollama

# Generic selected model (optional override)
# LLM_MODEL=llama3.1:8b

# Ollama settings
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.1:8b

# OpenAI settings (fill when LLM_PROVIDER=openai)
OPENAI_API_KEY=<openai_api_key>
OPENAI_MODEL=gpt-4o-mini

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_npa

# JWT Auth
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
